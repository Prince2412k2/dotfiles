{
  "layer": "overlay",
  "position": "top",
  // "exclusive": false,
  "height": 0,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "clock",
    "mpris"
  ],
  "modules-right": [
    "pulseaudio#output",
    "pulseaudio#input",
    "battery",
    "network",
    "memory",
    "custom/lock",
    "custom/bat"
  ],
  "hyprland/workspaces": {
    "format": "{name}: {icon}",
    "format-icons": {
      "active": "",
      "default": ""
    }
  },
  "clock": {
    "timezone": "Asia/Kolkkata",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "{:%d - %H:%M}"
  },
  "battery": {
    "full-at": 99,
    "interval": 60,
    "format-discharging": "{capacity}%",
    "format-charging": "{capacity}% ",
    "format-plugged": "{capacity}% ",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "network": {
    "format-wifi": "󰤢 ",
    "format-ethernet": "󰈀 ",
    "format-disconnected": "󰤮",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "{ifname} : {essid} : {signalStrength}",
    "on-click": "wf"
  },
  "memory": {
    "interval": 30,
    "format": "  {used:0.1f}G/{total:0.1f}G"
  },
  "pulseaudio#output": {
    "format": "{icon} {volume}",
    "format-muted": " ",
    "format-icons": {
      "default": [
        "",
        "",
        " "
      ]
    },
    "max-volume": 153,
    "on-click": "pavucontrol"
  },
  "pulseaudio#input": {
    "format-source": "",
    "format-source-muted": " ",
    "format": "{format_source}"
  },
  "custom/lock": {
    "tooltip": false,
    "on-click": "sh -c '(sleep 0.5s; hyprlock)' & disown",
    "format": ""
  },
  "later": {
    "format": "<span class='icon'>{icon}</span> <span class='text'>{text}</span>"
  },
  "custom/bat": {
    "format": "",
    "interval": 60,
    "exec": "$HOME/.config/waybar/scripts/bat_notif.sh"
  },
  "mpris": {
    "format": "{player_icon} {artist}",
    "format-paused": "{status_icon} <i>{artist}</i>",
    "tooltip-format": "{player}\n{dynamic}",
    "player-icons": {
      "default": "▶",
      "mpv": "🎵",
      "spotify": " "
    },
    "status-icons": {
      "paused": "⏸"
    },
    "ignored-players": [
      "zen-browser",
      "firefox"
    ]
  }
}
